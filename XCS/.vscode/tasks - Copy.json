{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build XCS",
            "type": "shell",
            "command": "g++ -g -O0 *.cpp -o xcs -I/usr/include/mariadb -ltinyxml2 -lmariadb",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "/app"
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
